{{!< default}}

{{#author}}

<header id="blog-header"{{#if cover_image}} class="has-cover"{{else}}{{#if @site.cover_image}} class="has-cover"{{/if}}{{/if}}>
	<div class="inner">
		{{#if cover_image}}
		<div class="blog-cover cover" style="background-image: url('{{img_url cover_image size="xl"}}');"></div>
		{{else}}
		{{#if @site.cover_image}}
		<div class="blog-cover cover" style="background-image: url('{{img_url @site.cover_image size="xl"}}');"></div>
		{{/if}}
		{{/if}}
	</div>
</header>

<section id="blog-author"{{#if cover_image}} class="has-cover"{{else}}{{#if @site.cover_image}} class="has-cover"{{/if}}{{/if}}>
	<div class="inner">
		<aside class="post-author">
			<figure class="post-author-avatar avatar">
				{{#if profile_image}}
				<img src="{{profile_image}}" alt="{{name}}" />
				{{/if}}
			</figure>
			<div class="post-author-bio">
				<h2 class="post-author-name">{{name}}</h2>
				{{#if bio}}
				<p class="post-author-about">{{{bio}}}</p>
				{{/if}}
				<span class="post-author-stats">{{plural ../pagination.total empty=(t "No Posts") singular=(t "% Post") plural=(t "% Posts")}}</span>
				{{#if website}}
				<span class="post-author-website"><a target="_blank" href="{{website}}">{{t "Website"}}</a></span>
				{{/if}}
				{{#if twitter}}
				<span class="post-author-twitter"><a target="_blank" href="{{social_url type="twitter"}}">{{t "Twitter"}}</a></span>
				{{/if}}
				{{#if facebook}}
				<span class="post-author-facebook"><a target="_blank" href="{{social_url type="facebook"}}">{{t "Facebook"}}</a></span>
				{{/if}}
			</div>
			<div class="clear"></div>
		</aside>
	</div>
</section>

{{/author}}

<div id="index" class="container">

	<main class="content" role="main">

		{{> "loop"}}

	</main>

</div>
